# --- Supabase ---
# Public project URL, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Anon key, safe to expose to the browser (RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - SERVER ONLY. Never expose with NEXT_PUBLIC_ prefix.
# Used to insert/select/delete trade_inquiries, bypassing RLS from trusted server code only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stealth Admin Vault ---
# The passcode a real human types into the modal. Keep this secret and rotate periodically.
ADMIN_PASSCODE=change-this-to-a-long-random-passcode

# Secret used to sign the admin session JWT. Generate with: openssl rand -base64 48
ADMIN_JWT_SECRET=change-this-to-a-long-random-string

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
